{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 24, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "macos-metal",
      "displayName": "macOS (Metal)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "/opt/homebrew/Cellar/qt/6.11.1"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "linux-vulkan",
      "displayName": "Linux (Vulkan)",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "windows-d3d",
      "displayName": "Windows (Direct3D)",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "buildPresets": [
    { "name": "macos-metal", "configurePreset": "macos-metal" },
    { "name": "linux-vulkan", "configurePreset": "linux-vulkan" },
    { "name": "windows-d3d", "configurePreset": "windows-d3d" }
  ]
}
